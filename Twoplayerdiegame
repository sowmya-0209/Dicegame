<!DOCTYPE html>
<html>
<head>
<title>2 Player Dice Game</title>

<style>
body{
  background: lightpink;
  font-family: Arial;
  text-align: center;
}

h1{
  color: white;
  margin-top: 30px;
}

.container{
  display: flex;
  justify-content: center;
  gap: 80px;
  margin-top: 60px;
}

.player-box{
  text-align: center;
}

button{
  width:120px;
  height:120px;
  font-size:20px;
  border:none;
  border-radius:10px;
  cursor:pointer;
}

.btn1{ background: teal; color:white; }
.btn2{ background: purple; color:white; }

.score{
  font-size:30px;
  margin-top:10px;
}

.result{
  margin-top:40px;
  font-size:28px;
  color:white;
}
</style>

</head>

<body>

<h1>🎲 2 Dice Game</h1>

<div class="container">

<div class="player-box">
<h2>Player 1</h2>
<button class="btn1" onclick="roll(1)">Roll</button>
<div class="score" id="p1">0</div>
</div>

<div class="player-box">
<h2>Player 2</h2>
<button class="btn2" onclick="roll(2)">Roll</button>
<div class="score" id="p2">0</div>
</div>

</div>

<div class="result" id="result"></div>

<script>

let dice=[0,0];
let turns=[0,0];

function roll(n){

if(turns[n-1]==0){

dice[n-1]=Math.floor(Math.random()*6)+1;

document.getElementById("p"+n).innerHTML=dice[n-1];

turns[n-1]=1;

checkWinner();

}

}

function checkWinner(){

if(turns[0]==1 && turns[1]==1){

if(dice[0]>dice[1]){
document.getElementById("result").innerHTML="Player 1 Wins 🎉";
}

else if(dice[1]>dice[0]){
document.getElementById("result").innerHTML="Player 2 Wins 🎉";
}

else{
document.getElementById("result").innerHTML="It's a Tie 🤝";
}

}

}

</script>

</body>
</html>